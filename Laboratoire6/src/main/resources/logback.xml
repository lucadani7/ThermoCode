<configuration debug="false">
    <conversionRule conversionWord="statusColor" class="utcb.fii.utils.CustomColorConverter" />

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} [%thread] %statusColor(%-5level) %logger{36} - %statusColor(%msg) %n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT" />
    </root>
</configuration>